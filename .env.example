# LiveRex — environment variables
# Copy this file to .env and fill in your keys.
# Never commit .env to version control.

# GCP Project Configuration
GCP_PROJECT_ID=your-project-id
GCP_LOCATION=asia-northeast1

# Google Speech-to-Text V2 Recognizer Path
# Format: projects/{project_id}/locations/{location}/recognizers/{recognizer_id}
# Use "_" for the default recognizer
GCP_STT_RECOGNIZER=projects/your-project-id/locations/asia-northeast1/recognizers/_
